# App
APP_ENV=local
API_PORT=8000

# Broker (Redpanda)
REDPANDA_BROKERS=redpanda:9092
EVENTS_TOPIC=events.raw
DLQ_TOPIC=events.dlq
PUBLISHER_READY_TIMEOUT_SECONDS=1.0
PUBLISHER_START_MAX_ATTEMPTS=5
PUBLISHER_START_BACKOFF_SECONDS=2.0

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=events
POSTGRES_USER=events_user
POSTGRES_PASSWORD=events_password

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
